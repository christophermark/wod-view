# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# env files — this repo is PUBLIC; no secrets, anywhere, ever.
# Only the all-commented fastlane template is allowed back in.
.env
.env.*
.env*.local
!fastlane/.env.default

# credential files that tooling might drop in the tree (defensive)
credentials.json
*service-account*.json
google-services.json
GoogleService-Info.plist

# Fastlane build output, generated reports, and local secrets
# (.env.default is the committed template; .env holds the real values)
/build/fastlane/
/fastlane/.env
/fastlane/*.json
/fastlane/Preview.html
/fastlane/report.xml
/fastlane/screenshots/
/fastlane/test_output/
/vendor/bundle/

# Android signing material (keep keystores outside the repo anyway)
*.keystore

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

# maestro e2e output
/.maestro/screenshots/

# marketing screenshot output (regenerate with npm run screenshots)
/.maestro/marketing/raw/
/.maestro/marketing/out/

# personal workout data (SugarWOD export + generated JSON)
/data/workouts.csv
/src/data/workouts.json
# generated from the committed sample CSV on postinstall
/src/data/preview-workouts.json
